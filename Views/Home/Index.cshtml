@model DataViewerApp.Models.IndexViewModel
@{
    ViewData["Title"] = "データビューアー";
    var queryId = Context.Request.Query["queryId"].ToString();
}
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen flex flex-col">

    <!-- ヘッダー -->
    <header class="bg-blue-700 text-white px-6 py-3 shadow-md flex items-center gap-3">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2"
             viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M4 6h16M4 10h16M4 14h16M4 18h16" />
        </svg>
        <span class="text-xl font-semibold tracking-wide">Data Viewer</span>
    </header>

    <!-- メインレイアウト -->
    <div class="flex flex-1 overflow-hidden">

        <!-- サイドバー -->
        <aside class="w-56 bg-white border-r border-gray-200 shadow-sm flex-shrink-0 overflow-y-auto">
            <nav class="py-4">
                <p class="px-4 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">
                    メニュー
                </p>
                <ul>
                    @foreach (var item in Model.MenuItems)
                    {
                        var isActive = item.Id == queryId;
                        <li>
                            <a href="./?queryId=@item.Id"
                               class="flex items-center gap-2 px-4 py-2.5 text-sm font-medium transition-colors
                                      @(isActive
                                          ? "bg-blue-50 text-blue-700 border-l-4 border-blue-600"
                                          : "text-gray-700 hover:bg-gray-50 hover:text-blue-600 border-l-4 border-transparent")">
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor"
                                     stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7" />
                                </svg>
                                @item.MenuName
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        </aside>

        <!-- メインコンテンツ -->
        <main class="flex-1 p-6 overflow-auto">

            @if (Model.SelectedQuery is null)
            {
                <!-- 未選択時の案内 -->
                <div class="flex flex-col items-center justify-center h-full text-gray-400 gap-4 mt-20">
                    <svg class="w-16 h-16" fill="none" stroke="currentColor" stroke-width="1.5"
                         viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M3 7h18M3 12h18M3 17h18" />
                    </svg>
                    <p class="text-lg font-medium">左のメニューからデータを選択してください</p>
                </div>
            }
            else
            {
                <!-- タイトルとエクスポートボタン -->
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
                    <h2 class="text-lg font-semibold text-gray-800">
                        @Model.SelectedQuery.MenuName
                        <span class="ml-2 text-sm font-normal text-gray-500">
                            (@Model.Rows.Count 件)
                        </span>
                    </h2>
                    <div class="flex gap-2">
                        <a href="/Home/ExportCsv?queryId=@Model.SelectedQuery.Id"
                           class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-white
                                  bg-green-600 hover:bg-green-700 rounded-md shadow-sm transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"
                                 viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1M12 12v9m0 0l-3-3m3 3l3-3M12 3v9" />
                            </svg>
                            CSV ダウンロード
                        </a>
                        <a href="/Home/ExportExcel?queryId=@Model.SelectedQuery.Id"
                           class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-white
                                  bg-blue-600 hover:bg-blue-700 rounded-md shadow-sm transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"
                                 viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1M12 12v9m0 0l-3-3m3 3l3-3M12 3v9" />
                            </svg>
                            Excel ダウンロード
                        </a>
                    </div>
                </div>

                <!-- データテーブル -->
                <div class="bg-white rounded-lg shadow overflow-x-auto">
                    @{
                        var dbCols = Model.Rows.Count > 0 ? Model.Rows[0].Keys.ToList() : new List<string>();
                    }
                    @if (Model.Rows.Count == 0)
                    {
                        <div class="flex flex-col items-center justify-center py-16 text-gray-400">
                            <svg class="w-10 h-10 mb-3" fill="none" stroke="currentColor"
                                 stroke-width="1.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V7a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                            <p class="text-sm">データがありません</p>
                        </div>
                    }
                    else
                    {
                        <table class="min-w-full divide-y divide-gray-200 text-sm">
                            <thead class="bg-gray-50">
                                <tr>
                                    @foreach (var col in Model.DisplayColumns)
                                    {
                                        <th class="px-4 py-3 text-left font-semibold text-gray-600
                                                   uppercase tracking-wider whitespace-nowrap">
                                            @col
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                @foreach (var row in Model.Rows)
                                {
                                    <tr class="hover:bg-blue-50 transition-colors">
                                        @foreach (var col in dbCols)
                                        {
                                            <td class="px-4 py-2.5 text-gray-700 whitespace-nowrap">
                                                @(row.TryGetValue(col, out var v) ? v?.ToString() : string.Empty)
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            }
        </main>
    </div>

    <!-- フッター -->
    <footer class="bg-white border-t border-gray-200 px-6 py-2 text-xs text-gray-400 text-right">
        DataViewerApp &copy; @DateTime.Now.Year
    </footer>

</body>
</html>
